#include <bits/stdc++.h>
using namespace std;
 
int solve()
{
    int n, k;
    cin >> n >> k;
    vector<int> v(n);
    int count = 0;
    
    for(int i = 0; i < n; i++) {
        cin >> v[i];
    }
    
    for(int i = 0; i < n; i++) {
        if(v[i] >= v[k-1] && v[i] > 0) {
            count++;
        }
    }
    return count;
}
int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
    
    cout << solve();
    return 0;
}
