#include <bits/stdc++.h>
using namespace std;

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
    
    int n, k;
    cin >> n >> k;
    
    while(k > 0) {
        if(n % 10 != 0) {
            n--;
            k--;
        }
        else if(n % 10 == 0) {
            n /= 10;
            k--;
        }
    }
    cout << n;

    return 0;
}
