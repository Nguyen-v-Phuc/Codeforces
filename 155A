#include <bits/stdc++.h>
using namespace std;

int main()
{
    int n;
    cin >> n;
    vector<int> v(n);
    
    int amazing = 0;
    
    for(int i = 0; i < n; i++) {
        cin >> v[i];
    } 
    
    int max = v[0];
    int min = v[0];
    
    for(int i = 0; i < n; i++) {
        if(v[i] > max) {
            max = v[i];
            amazing++;
        }
        else if(v[i] < min) {
            min = v[i];
            amazing++;
        }
    }
    cout << amazing;
    return 0;
}
