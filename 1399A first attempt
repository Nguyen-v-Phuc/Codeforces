#include <bits/stdc++.h>
using namespace std;

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
    
    int tc;
    cin >> tc;
    
    while(tc--) {
        int n;
        cin >> n;
        vector<int> v(n);
        for(int i = 0; i < n; i++) {
            cin >> v[i];
        }
        
        for(int i = 0; i < n; i++) {
            for(int j = 1; j < n; j++) {
                if(abs(v[i] - v[j]) <= 1 && v[i] <= v[j]) {
                    swap(v[i], v.back()); 
                    v.pop_back(); 
                }
                else if(abs(v[i] - v[j]) <= 1 && v[j] <= v[i]) {
                    swap(v[j], v.back()); 
                    v.pop_back(); 
                }
                else if(v[i] == v[j]) {
                    swap(v[i], v.back()); 
                    v.pop_back(); 
                }
            }
            if(v.size() <= 1) {
                cout << "YES\n";
                break;
            }
            else {
                cout << "NO\n";
                break;
            }
        }
    }
    return 0;
}
