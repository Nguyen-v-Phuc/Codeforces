#include <bits/stdc++.h>
using namespace std;
#define ll long long
#define FOR(i, a, b) for(int i = a; i < b; i++)

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
    
    int n;
    cin >> n;
    vector<int> v(n);
    FOR(i, 0, n) {
        cin >> v[i];
    }
    
    int alice = 0, bob = 0;
    int l = 0, r = n-1;
    int alice_time = 0;
    int bob_time = 0;
    
    while(l <= r) {
        if(alice_time <= bob_time) {
            alice_time += v[l];
            alice++;
            l++;
        }
        else if(alice_time > bob_time) {
            bob_time += v[r];
            bob++;
            r--;
        }
    }
    cout << alice << " " << bob;
    return 0;
}
