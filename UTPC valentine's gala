#include <bits/stdc++.h>

using namespace std;

#define ll long long
#define FOR(i, a, b) for(int i = a; i < b; i++)
#define FORD(i, a, b) for(int i = a; i > b; i--)
#define INFINT 2e9 // 2e9
#define INFLL 2e18 // 2e18
#define esp 1e-9
#define PI 3.14159265

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
    
    int n;
    cin >> n;
    vector<vector<int>> m(n, vector<int>(n, 0));
    
    FOR(i, 0, n) {
        FOR(j, 0, n) {
            cin >> m[i][j];
        }
    }
    
    double cnt = 0;
    
    FOR(i, 0, n) {
        FOR(j, 0, n) {
            if(m[i][j] == 1 && m[j][i] == 1) {
                cnt += 0.5;
            }
        }
    }
    cout << cnt;
    
    return 0;
}
