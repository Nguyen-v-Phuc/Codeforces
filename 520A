#include <bits/stdc++.h>
using namespace std;

int main()
{
    int n;
    string s;
    
    cin >> n;
    cin >> s;
    
    string seen(26, '0');
    
    if(n < 26) {
        cout << "NO";
        return 0;
    }
    
    for(char c : s) {
        c = tolower(c);
        seen[c - 'a'] = 1;
    }
    
    for(char c : seen) {
        if(c == '0') {
            cout << "NO";
            return 0;
        }
    }
    cout << "YES";
    return 0;
}
